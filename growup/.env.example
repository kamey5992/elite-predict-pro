# Supabase (trouvé dans ton dashboard Supabase > Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://ton-projet.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=ta-cle-anon-ici

# URL Netlify de ton site (pour les redirections Stripe)
EXPO_PUBLIC_NETLIFY_URL=https://elite-predict-pro.netlify.app

# Stripe — prix des abonnements (créés dans le dashboard Stripe > Products)
EXPO_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_xxxxxxxxxxxxxxxx
EXPO_PUBLIC_STRIPE_PRICE_PRO_YEARLY=price_xxxxxxxxxxxxxxxx
EXPO_PUBLIC_STRIPE_PRICE_ELITE_MONTHLY=price_xxxxxxxxxxxxxxxx
EXPO_PUBLIC_STRIPE_PRICE_ELITE_YEARLY=price_xxxxxxxxxxxxxxxx

# ─── Variables côté serveur Netlify (NE PAS mettre dans l'app mobile) ───────

# Stripe — clés secrètes (Netlify > Site Settings > Environment Variables)
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO_MONTHLY=price_xxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO_YEARLY=price_xxxxxxxxxxxxxxxx
STRIPE_PRICE_ELITE_MONTHLY=price_xxxxxxxxxxxxxxxx
STRIPE_PRICE_ELITE_YEARLY=price_xxxxxxxxxxxxxxxx

# PayDunya — Mobile Money CI (Wave, Orange Money, Moov Money)
# Inscription sur paydunya.com (gratuit)
PAYDUNYA_MASTER_KEY=live_master_xxxxxxxxxxxxxxxx
PAYDUNYA_PRIVATE_KEY=live_private_xxxxxxxxxxxxxxxx
PAYDUNYA_TOKEN=live_token_xxxxxxxxxxxxxxxx

# Supabase — clé service (pour les webhooks uniquement, JAMAIS dans l'app)
SUPABASE_URL=https://ton-projet.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ton-service-role-key-ici
